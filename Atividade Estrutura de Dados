#include <stdio.h>
#include <conio.h>
#include <stdlib.h>

int linhasTotais, colunasTotais, tamanhoTotal;

void adicionarElemento (int *vet, int valor, int posicaoI, int posicaoJ){
	vet[(((posicaoI-1) * colunasTotais) + (posicaoJ-1))] = valor;	
	/*(i * colunasTotais + j) Índice Linear para vetorização;
	Esse trecho encontra o índice linear e atribui o valor 0 para todas as posições da matriz;*/
}

int buscarElemento (int *vet, int posicaoI, int posicaoJ){
	return vet[((posicaoI-1) * colunasTotais) + (posicaoJ-1)];
}

void zerarMatriz (int *vet){
    int i, j;
    for (i=1; i <= linhasTotais; i++){
        for (j=1; j <= colunasTotais; j++){
            adicionarElemento (vet, 0, i, j);
        }
    }
}

void tamanhoMatriz (int linhas, int colunas){
	linhasTotais = linhas;
	colunasTotais = colunas;
	tamanhoTotal = linhas * colunas;
}

int verificaMatrizQuadrada (){
	if (linhasTotais == colunasTotais){
		return 1;
	}else{
		return 0;
	}
}

int verificaMatrizIdentidade (int *vet){
	int i, j;
	for (i=1; i <= linhasTotais; i++){
        for (j=1; j <= colunasTotais; j++){
        	if (i==j){
        		if (buscarElemento(vet, i, j) != 1){
        		return 0;
				}
			}
			else if (buscarElemento(vet, i, j) != 0){
				return 0;
        	}
		}
	}
    return 1;
}

int verificaMatrizInversa(int *vetA, int *vetB){
	if (!(verificaMatrizQuadrada())){
    printf("Erro: matriz nao eh quadrada\n");
    return 0;
	}
	int i, j, k;
	int matrizResultante[tamanhoTotal];
	zerarMatriz (matrizResultante);
	for (i=1; i <= linhasTotais; i++){
        for (j=1; j <= colunasTotais; j++){
        	int somaDosProdutos = 0;
        	for (k=1; k <= linhasTotais; k++){
        		somaDosProdutos += buscarElemento(vetA, i, k) * buscarElemento(vetB, k, j); 
			}
			adicionarElemento (matrizResultante, somaDosProdutos, i, j);		
        }
    }
    return verificaMatrizIdentidade (matrizResultante);
}

void imprimirMatriz (int *vet){
	int i, j;
    for (i=1; i<=linhasTotais; i++){
        for (j=1; j<=colunasTotais; j++){
			int valorBuscarElemento = buscarElemento (vet, i, j);
			printf("%d ", valorBuscarElemento);
        }
        printf("\n");
    }
    printf("\n");
}

void somaMatriz (int *vet1, int *vet2, int *vet3){
	int i, j;
    for (i=1; i<=linhasTotais; i++){
        for (j=1; j<=colunasTotais; j++){
        	int valor = buscarElemento(vet1, i, j) + buscarElemento(vet2, i, j);
            adicionarElemento(vet3, valor, i, j);
        }
    }
}

int numeroEntradasCidade (int *vet, int k){
	int i; 
    int contadorEntradas = 0; 
    for (i=0; i<linhasTotais; i++){
    	int valorEntradas = buscarElemento(vet, i+1, k+1);
		if (k != i && valorEntradas == 1){
			contadorEntradas++;
		}		
	}
	return contadorEntradas;
}

int numeroSaidasCidade (int *vet, int k){
	int j; 
	int contadorSaidas= 0; 
	for (j=0; j<colunasTotais; j++){
		int valorSaidas = buscarElemento(vet, k+1, j+1); 
			if (k != j && valorSaidas == 1){
			contadorSaidas++;
		}			
	}
	return contadorSaidas;
}

//i. As cidades isoladas, isto é, as que não têm ligação com nenhuma outra;
void cidadesIsoladas (int *vet){
	if (verificaMatrizQuadrada()){
		int k;
		for (k=0; k<linhasTotais; k++){
			int resultadoContadorEntradas = numeroEntradasCidade (vet, k);
			int resultadoContadorSaidas = numeroSaidasCidade (vet, k);
			if (resultadoContadorSaidas == 0 && resultadoContadorEntradas == 0){
				printf("%d eh uma cidade isolada\n", k);
			}
		}
	} else {
		    printf("Erro: matriz nao eh quadrada\n");
	}	
}

//ii. As cidades das quais não há saída, apesar de haver entrada;
void cidadesComEntradaESemSaida (int *vet){
	if (verificaMatrizQuadrada()){
		int k;
		for (k=0; k<linhasTotais; k++){
			int resultadoContadorEntradas = numeroEntradasCidade (vet, k);
			int resultadoContadorSaidas = numeroSaidasCidade (vet, k);
			if (resultadoContadorSaidas == 0 && resultadoContadorEntradas != 0){
				printf("%d eh uma cidades das quais nao ha saida, apesar de haver entrada\n", k);
			}
		}
		
	} else {
		printf("Erro: matriz nao eh quadrada\n");	
	}		
}

//iii. As cidades das quais há saída sem haver entrada.
void cidadesComSaidaESemEntrada (int *vet){
	if (verificaMatrizQuadrada()){
		int k;
		for (k=0; k<linhasTotais; k++){
			int resultadoContadorEntradas = numeroEntradasCidade (vet, k);
			int resultadoContadorSaidas = numeroSaidasCidade (vet, k);
			if (resultadoContadorSaidas != 0 && resultadoContadorEntradas == 0){
				printf("%d eh uma cidades das quais ha saida sem haver entrada\n", k);
			}
		}
	} else {
		printf("Erro: matriz nao eh quadrada\n");
	}		
}

//iv. A qual das cidades chega o maior número de estradas
void cidadesMaiorNumeroEstradas (int *vet){
	if (verificaMatrizQuadrada()){
		int k, listaNumeroEstradasCidades[colunasTotais], maiorValor=0;
		for (k=0; k<linhasTotais; k++){
			int resultado = numeroEntradasCidade (vet, k);
			listaNumeroEstradasCidades [k] = resultado;
			maiorValor = maiorValor <= resultado ? resultado : maiorValor; 
		}
		for (k=0; k<linhasTotais; k++){
			if (listaNumeroEstradasCidades[k] == maiorValor){
				printf("%d eh uma cidades das quais chega o maior numero de estradas\n", k);
			}
		}
	} else {
		printf("Erro: matriz nao eh quadrada\n");
	}		
}

//v. Relacionar as cidades que possuem saídas diretas para a cidade k.
void cidadesSaidas (int *vet, int cidade){
	if (verificaMatrizQuadrada()){
		int k=cidade, j;
		for (j=0; j<colunasTotais; j++){
			if (k!=j && buscarElemento (vet, j+1, k+1) == 1){
				printf("%d tem saida para %d\n", j, k);
			}
		}
	} else {
		printf("Erro: matriz nao eh quadrada\n");
	}
}

